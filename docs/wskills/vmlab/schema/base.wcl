// wskill base schema — ships with the WSKILL skill scaffold.
//
// Schema version: 1.3.0 (mirror it in `schema_version` in wskill.wcl).
// 1.3.0 is additive over 1.2.0: multiple skills per wskill (`skill` gains
// optional name/description identity overrides; each extra skill pairs with
// its own `:ai_skill` site) and shipped subagents (document-level wdoc
// `agent` blocks, peers of the skills) — 1.2.0 data validates unchanged.
//
// DO NOT HAND-EDIT. Everything topic-specific belongs in `extensions.wcl`, and
// the topic-owned vocabularies (entity kinds, artifact kinds) in `kinds.wcl` —
// that file IS hand-editable. This file is versioned with the WSKILL skill;
// upgrade procedures live in the skill's references. It defines the base block
// types (the wskill data model) and the root @document that gathers every
// block instance so the wdoc template sets can project over them.
//
// The schema travels with the document: a wskill folder is fully interpretable
// (lint + render) without the WSKILL skill present.
//
// Field decorators (@default, @inline, @child, @children) are PREFIX — they sit
// before the field they describe.
//
// All wskill declarations live in the `wcl.wskill` namespace. Importers (the root
// wskill.wcl, data files, wdoc templates) keep using bare names — a relative import
// auto-joins this namespace to the bare-name search path — and a name can be
// qualified (`wcl.wskill::concept`) when it would otherwise be ambiguous.
namespace wcl.wskill

import <wdoc.wcl>
import <answer.wcl>      // @answerable + the `option` block for `question`s
import "./kinds.wcl"     // topic-owned vocabularies (EntityKind, ArtifactKind)

// ---------------------------------------------------------------------------
// Shared row types
// ---------------------------------------------------------------------------

// Key/value attribute row — used by `entity.attributes` and `custom.attrs`.
// Authorable with WCL pipe-table syntax:
//   attributes:
//     | "flag" | "-l" |
//     | "name" | "long format" |
@table("attr")
type Attr {
  key:   utf8
  value: utf8
}

// ---------------------------------------------------------------------------
// Topic (one per wskill)
// ---------------------------------------------------------------------------

// The overarching subject — wraps everything inside the wskill — together with
// the wskill's own document-level metadata (creation/maintenance dates).
// Exactly one per wskill.
@block("topic")
type Topic {
  @inline(0) id: identifier      // topic ls { … }  → id = ls
  name:        utf8              // human title
  summary:     utf8              // one-line description
  description: utf8?             // longer prose (heredoc)
  version:     utf8?             // pinned upstream version, where the topic has one
  @default([]) tags: list<utf8>

  // Document-level metadata for the wskill itself (not topic content).
  created:    utf8               // ISO date the wskill was created
  updated:    utf8?             // ISO date of last full update sweep
  maintainer: utf8?
  maintainer_entity: identifier?  // entity id holding maintainer details; the book links to it
  note:       utf8?
}

// ---------------------------------------------------------------------------
// Skill (one per wskill — the skill-projection config + bundled artifacts)
// ---------------------------------------------------------------------------
//
// Skill artifacts (script / asset) are real files bundled into the emitted Claude
// Code skill (the `scripts/` and `assets/` folders a skill expects). They are
// authored as CHILDREN of the `skill` block below (so they drop the `skill_`
// prefix). The skill template ships each via wdoc's `file` block; the executable
// bit is preserved, so scripts arrive runnable. The book projection lists them with
// a download link (it cannot inline a file's bytes).
//
// Two fields carry the file's identity:
//   `source` — WHERE IT COMES FROM: the file's path under the wskill root, e.g.
//              "skill/scripts/build.sh". Templates resolve it relative to the root.
//   `name`   — WHAT IT IS CALLED IN THE RENDERED SKILL: the filename it ships as
//              under scripts/ or assets/, e.g. "build.sh".
// wdoc's `file` block names the copied output by the source's basename, so `name`
// must equal that basename. See references/schema.md.

// A runnable script shipped into the skill's scripts/ folder.
@block("script")
type Script {
  @inline(0) id: identifier
  source:      utf8             // where it comes from: path under the wskill root (e.g. "skill/scripts/build.sh")
  name:        utf8             // filename in the rendered skill (= basename of source, e.g. "build.sh")
  description: utf8             // what it does AND when to run it
  usage:       utf8             // invocation, e.g. "scripts/build.sh ARG"
  @default([]) tags: list<utf8>
}

// Optional custom SKILL.md summary content — a sub-block of `skill` whose plain
// fields are pulled onto the skill's start page (no wdoc body projection, which
// the `skill`/wdoc block-kind collision prevents). Author one inside `skill`.
@block("summary")
type Summary {
  @default([]) overview:   list<utf8>   // intro paragraph(s) under the topic summary
}

// An invocation parameter the skill accepts — rendered into the SKILL.md
// "Parameters" section. `name` is the Claude Code placeholder or label (e.g.
// "$ARGUMENTS", "$1", "$2"); `value` says how to determine what to pass. The kind
// is `skill_param` (not `parameter`, which the language module already declares).
@block("skill_param")
type SkillParam {
  @inline(0) name: utf8        // e.g. "$ARGUMENTS", "$1", "$2"
  description: utf8?           // what the parameter represents
  value:       utf8?          // how to determine / where to source the value
}

// Behavioural guardrails for the skill — rendered into SKILL.md inside
// `<Boundary> … </Boundary>` tags so an agent treats them as hard rules. The kind
// is `skill_boundary` (bare `boundary` collides with a wdoc diagram block).
@block("skill_boundary")
type SkillBoundary {
  @default([]) always: list<utf8>   // things to always do
  @default([]) ask:    list<utf8>   // things to ask before doing
  @default([]) never:  list<utf8>   // things to never do
}

// A static data file (fixture, dataset, sample config) shipped into assets/.
@block("asset")
type Asset {
  @inline(0) id: identifier
  source:      utf8             // where it comes from: path under the wskill root (e.g. "skill/assets/data.json")
  name:        utf8             // filename in the rendered skill (= basename of source, e.g. "data.json")
  description: utf8
  @default([]) tags: list<utf8>
}

// NOTE on shipped agents: a wskill's Claude Code subagents are authored as
// document-level wdoc `agent` blocks (peers of the `skill` blocks — an
// agent belongs to the wskill, not to one of its skills; see AgentConfig
// in wdoc's templates.wcl). The skill target writes each to
// agents/<name>.md at the output root, beside the skill folder(s), and
// installers copy them into a repo's .claude/agents/. The agent body is
// the standing role constitution; the dispatching orchestrator's prompt
// carries the per-task payload, so write it self-contained (a subagent
// never sees the session's own prompt).
//
//   agent "topic-helper" {
//     description = "Does one X task. Use when dispatching X work."
//     tools = ["Read", "Bash"]        // empty/omitted = unrestricted
//     model = "sonnet"                // omitted = inherit the session model
//     body { p "You are …" }          // the whole system prompt
//   }

// Controls written into the generated SKILL.md frontmatter, plus the bundled
// artifacts (script / asset children). A `skill` block kind is only possible
// because the schema is namespaced (`wcl.wskill::skill`) — bare it would collide
// with wdoc's own `skill` block. Defaults are absent-equivalent (empty list = no
// pre-approval / no restriction; false = model may invoke), so they are safe to
// always emit. A wskill ships ONE OR MORE skills: the templates bind the
// primary as `let skill = head(skills)`; a further skill block sets `name`
// (+ `description`) and pairs with its own `:ai_skill` site in the skill
// template (each site renders into its own subfolder of out/skill).
@block("skill")
type Skill {
  // Identity overrides — the PRIMARY skill omits both (the template derives
  // name from the topic id and generates the reference-style description);
  // every ADDITIONAL skill sets them (its install name and trigger text).
  name:        utf8?
  description: utf8?
  @default([])    allowed_tools:            list<utf8>   // → SKILL.md `allowed-tools`
  @default([])    disallowed_tools:         list<utf8>   // → `disallowed-tools`
  @default(false) disable_model_invocation: bool         // → `disable-model-invocation`
  // Bundled skill artifacts — authored nested inside the skill block.
  @children("script") skill_scripts: list<Script>
  @children("asset")  skill_assets:  list<Asset>
  // Optional custom SKILL.md summary content (pulled, not projected — see Summary).
  @children("summary") summary: list<Summary>
  // Invocation parameters documented in the SKILL.md "Parameters" section.
  @children("skill_param") parameters: list<SkillParam>
  // Behavioural guardrails rendered into SKILL.md inside <Boundary> tags.
  @children("skill_boundary") boundary: list<SkillBoundary>
}

// ---------------------------------------------------------------------------
// Sources (update-workflow metadata — never rendered as topic content)
// ---------------------------------------------------------------------------

// Where current/authoritative information about the topic lives. Drives the
// update workflow only; it carries no content. See references/workflow-update.md.
@block("source")
type Source {
  @inline(0) id: identifier
  kind:             utf8         // website | repo | book | docs (extensible)
  locator:          utf8         // URL, git URL, ISBN, or path
  covers:           utf8         // free text: what this source is good for
  last_checked:     utf8?       // ISO date the agent last consulted it
  reflects_version: utf8?       // upstream version this source described when checked
}

// ---------------------------------------------------------------------------
// Research (captured findings — dated, source-linked, rendered content)
// ---------------------------------------------------------------------------

// A research unit's lifecycle: :current (trustworthy as of `checked`) →
// :stale (flagged for a re-check on the next update sweep) → :superseded
// (kept for the record; `superseded_by` names the replacement unit).
symbol_set ResearchStatus { current stale superseded }

// A captured research finding — the durable output of an investigation: the
// question asked, what was found, how fresh it is, and where the evidence
// lives. Unlike `source` (a locator only, never rendered) a research unit IS
// content: the skill projection writes it to references/research_<id>.md —
// the fixed path an external consumer (e.g. a planning pipeline's researcher
// agent) globs to reuse findings instead of re-investigating — and lists it
// in references/index_research.md. Audience defaults to :ai (research is
// captured for agents first; opt into the book with :both) — note this
// deviates from the :book default the other content blocks use.
@block("research")
type Research {
  @inline(0) id: identifier
  topic:    utf8                          // headline (also the link text)
  question: utf8?                         // what the investigation set out to answer
  summary:  utf8                          // one-line finding, for the research index
  @default(:current) status: ResearchStatus
  checked:  utf8                          // ISO date the finding was last verified
  applies_to: utf8?                       // subject/version the finding holds for (e.g. "bevy 0.18")
  @default([]) source_ids: list<identifier> // backing `source` block ids
  @default([]) locators:   list<utf8>     // ad-hoc evidence (URLs/paths) not worth a source block
  superseded_by: identifier?              // replacement research unit, when :superseded
  @default([]) related: list<identifier>  // ids of related units (any kind)
  @default(:ai) audience: Audience        // :ai (default) | :book | :both
  @default([]) tags: list<utf8>
  // The findings — an addressable `body { …wdoc… }`, projected onto its page.
  @child("body") body: WdocAddressableBody?
}

// ---------------------------------------------------------------------------
// Open questions (update-workflow metadata, answered via answer mode)
// ---------------------------------------------------------------------------

// A question's lifecycle: :open (needs an answer) → :answered, or :dropped
// when it is withdrawn/skipped.
symbol_set QuestionStatus { open answered dropped }

// How a choice question presents: one pick, several, or plain text. Free text
// is ALWAYS also available — options accelerate, they never constrain.
symbol_set QuestionKind { single_select multi_select free_text }

// An open question about the topic, captured while authoring: an unclear
// fact, a decision only the topic owner can make, a gap found during an
// update sweep. Wired for guided answer mode via `@answerable` —
// `wcl answer wskill.wcl` walks the :open ones in the terminal and writes
// `answer` + `status` straight back into the data file, one question at a
// time. When `kind` is omitted, a question with `option`
// children behaves as :single_select and one without as :free_text.
// Like `source`, a question is update-workflow metadata and never renders
// as topic content: fold an :answered question's answer into real units on
// the next sweep, then delete the block.
@answerable(prompt = "question", response = "answer", status = "status",
            pending = :open, resolved = :answered, skipped = :dropped)
@block("question")
type Question {
  @inline(0) id: identifier
  question: utf8                 // the prompt shown to the respondent
  @default(:open) status: QuestionStatus
  answer:   utf8?                // written by answer mode (or by hand)
  kind:     QuestionKind?        // omit to infer from the presence of options
  context:  utf8?                // why it's asked / what the answer unblocks
  unit:     identifier?          // unit the answer should update, when known
  // Choices, as `option <id> { label = … }` children (the answer stdlib's
  // block; `label` falls back to the option's id).
  @children("option") options: list<AnswerOption>
  @default([]) tags: list<utf8>
}

// ---------------------------------------------------------------------------
// Cross-references to other wskills
// ---------------------------------------------------------------------------

// A relationship to another wskill. Resolved by `name` against repo peers /
// the collection manifest first, by `url` otherwise. `status = "planned"` is
// the stub form: it renders but the validator reports it as a warning so the
// planned-skill backlog stays visible without blocking renders.
@block("wskill_ref")
type WskillRef {
  @inline(0) id: identifier
  name:     utf8                 // referenced wskill's topic name
  url:      utf8?               // git URL when not a repo peer
  relation: utf8?               // "builds on", "see also", "prerequisite"
  @default("exists") status: utf8     // "exists" | "planned"
}

// ---------------------------------------------------------------------------
// Artifacts — the views this wskill ships, as first-class described data
// ---------------------------------------------------------------------------

// One shipped view (book / ai_skill / presentation / training — the ArtifactKind
// vocabulary lives in schema/kinds.wcl). The book overview lists these, a
// registry landing can enumerate them, and processes can name them in prose.
// Declaring an artifact documents that `entry` exists and renders to `output`;
// it does not build anything by itself.
@block("artifact")
type Artifact {
  @inline(0) id: identifier
  kind:    ArtifactKind          // which view family (see schema/kinds.wcl)
  name:    utf8?                 // display name; the templates default it per kind
  summary: utf8?
  entry:   utf8                  // projection entry file, e.g. "wdoc/book/main.wcl"
  output:  utf8?                 // conventional output dir, e.g. "out/book"
}

// ---------------------------------------------------------------------------
// Reference blocks
// ---------------------------------------------------------------------------
//
// Every content block below carries an `audience` field (the `Audience` symbol_set
// declared just below) controlling which projections render it.
//
// concept / entity / fact are the three interlinking *units of information*. Each
// is a thin record — an id, a headline, audience/tags — plus a rich **wdoc body**:
// an addressable `body { … }` holding arbitrary wdoc blocks (paragraphs, tables,
// code, callouts, links). Each unit renders to its own page (`<kind>_<id>`), and
// the body rides on the record as a property, `project`ed onto its page from the
// template (`project { from = c.body }`). `related` lists the ids of other units
// (any of the three kinds — ids are unique across them); the templates resolve each
// to a link to that unit's page. Bodies can also link inline with `[text](<kind>_<id>)`.

// Which projections a content block renders into: `:book` (default — human docs
// only), `:ai` (skill/agent-only notes), or `:both`. A symbol_set, so an unknown
// value is a `wcl check` error. The per-field default is `:book`, so content stays
// out of the skill until opted in with `:ai` / `:both` — curate the skill up. A
// `step` inherits its procedure's choice.
symbol_set Audience { book ai both }

// An idea the reader must understand.
@block("concept")
type Concept {
  @inline(0) id: identifier
  name:    utf8                          // headline (also the link text)
  summary: utf8                          // one-liner for the concept index
  @default([]) related: list<identifier> // ids of related units (concept/entity/fact)
  @default(:book) audience: Audience     // :book (default) | :ai | :both
  @default([]) tags: list<utf8>
  // The body — an addressable `body { …wdoc… }`, projected onto the page.
  @child("body") body: WdocAddressableBody?
}

// A concrete NAMED thing in the topic's world — a person, an organization, a
// piece of software, a command, a file format, a place. NOT a catch-all: an
// idea is a `concept`, a value/table is a `fact`, a repeatable task is a
// `procedure`. `kind` classifies it against the closed EntityKind vocabulary
// (schema/kinds.wcl — extend the set there when a topic needs a new kind).
@block("entity")
type Entity {
  @inline(0) id: identifier
  name:    utf8
  kind:    EntityKind                    // e.g. :software, :person (see schema/kinds.wcl)
  summary: utf8?                         // optional one-liner for the index
  @default([]) related: list<identifier>
  @default(:book) audience: Audience     // :book (default) | :ai | :both
  @default([]) tags: list<utf8>
  // The body — an addressable `body { …wdoc… }` (attributes go in a table here).
  @child("body") body: WdocAddressableBody?
}

// A factual unit — a container for values, constants, value tables. The `title`
// names it; the body holds the data (a `table`, `code`, prose).
@block("fact")
type Fact {
  @inline(0) id: identifier
  title:   utf8                          // headline (also the link text)
  @default([]) related: list<identifier>
  @default(:book) audience: Audience     // :book (default) | :ai | :both
  @default([]) tags: list<utf8>
  // The body — an addressable `body { …wdoc… }`, projected onto the page.
  @child("body") body: WdocAddressableBody?
}

// An index — a curated grouping that pins units (concepts / entities / facts /
// procedures) into a topic-meaningful arrangement. Unlike concept/entity/fact/
// procedure it is NOT filed under Reference: each index is a top-level entry in
// the book navigation (between Overview and Reference). In the BOOK it renders as
// a sidebar heading (no page of its own) whose children are the unit pages named
// in `related`, pinned into the nav tree. In the SKILL it renders as a
// link-collection page: the `body` (an addressable `body { … }`) holds the
// curated prose and `related` auto-resolves to a link list (so `body` is read by
// the skill projection only).
// An index may nest child indexes one level deep (`@children("index")`): write a
// child `index { … }` block inside the parent and both projections render it
// nested — under the parent heading in the book nav, indented under the parent
// bullet in the skill. Document-level `@children("index")` gathers only direct
// children, so a nested index is not also listed at the top level.
@block("index")
type Index {
  @inline(0) id: identifier
  name:    utf8
  summary: utf8?
  @default([]) related: list<identifier>
  @default(:book) audience: Audience     // :book (default) | :ai | :both
  @default([]) tags: list<utf8>
  @child("body") body: WdocAddressableBody?
  @children("index") children: list<Index>   // nested sub-indexes (one level rendered)
}

// A glossary entry.
@block("term")
type Term {
  @inline(0) id: identifier
  term:       utf8
  definition: utf8
  @default([]) aliases: list<utf8>
  @default(:book) audience: Audience     // :book (default) | :ai | :both
  @default([]) tags: list<utf8>
}

// A worked example or code sample. It is NOT a section of its own — it projects
// onto a unit: `unit` names the id of the concept/entity/fact it illustrates, and
// the templates render it on that unit's page (after the body).
@block("example")
type Example {
  @inline(0) id: identifier
  title:     utf8
  unit:      identifier?       // owning concept / entity / fact id (renders on its page)
  narrative: utf8?
  code_lang: utf8?             // language tag for the code listing
  code:      utf8?             // the sample (raw heredoc in data)
  expected:  utf8?             // expected result / output
  @default(:book) audience: Audience     // :book (default) | :ai | :both
  @default([]) tags: list<utf8>
}

// ---------------------------------------------------------------------------
// Processes (ordered step blocks)
// ---------------------------------------------------------------------------

// The flowchart shape a step draws in the process flow chart: a `process` box
// (an action), a `decision` diamond (a branch), or a `terminator` oval (start/end).
symbol_set StepShape { process decision terminator }

// The label on a flow edge between two steps: `:default` is a plain arrow, while
// `:yes` / `:no` annotate the branches out of a decision step.
symbol_set StepFlowKind { default yes no }

// One step in a process (procedure). The label is its `id` — the name the
// procedure's `from -> to` flow statements wire together. `n` is its display
// number and `shape` its flow-chart shape.
@block("step")
type Step {
  @inline(0) id: identifier
  n: u32                                  // display number (gutter / "Step N")
  title: utf8?
  @default(:process) shape: StepShape     // its shape in the flow chart
  // Two addressable body fragments per step: `body screen { … }` (what's on screen —
  // a callout/code/image box) and `body steps { … }` (the steps to follow — a list).
  // The book lays the number in a gutter beside the title; both fragments project
  // full-width below, in order, via a single `project { from = s.bodies }`.
  @children("body") bodies: list<WdocAddressableBody>
}

// A directed flow edge between two steps, authored as `from -> to` (optionally
// `from -> to :yes` / `:no`) in the procedure body — the wiring the flow chart draws.
connection StepFlow: Step -> Step : StepFlowKind

// A runbook for *doing* a specific task. Written for someone who already knows
// the topic and needs the reliable sequence. A `procedure` is a fourth interlinking
// unit (alongside concept/entity/fact) — it keeps its structured, step-based shape,
// but carries `related` and renders to its own page, so units can link to and from
// it. Its steps render as a flow chart (wired by the author's `from -> to` flow
// statements) above the step detail. (`process` is the user-facing name; the block
// is `procedure`.)
@block("procedure", required_children = ["step"])
type Procedure {
  @inline(0) id: identifier
  title:         utf8
  purpose:       utf8
  @default([]) preconditions: list<utf8>
  verification:  utf8?         // "how you know it worked"
  @default([]) related: list<identifier>   // ids of related units (any kind)
  @default(:book) audience: Audience     // :book (default) | :ai | :both
  @default([]) tags: list<utf8>
  @children("step") steps: list<Step>
  @connections(StepFlow) flow: list<StepFlow>   // the `from -> to` step wiring
}

// ---------------------------------------------------------------------------
// Custom content: declare a typed @block in extensions.wcl
// ---------------------------------------------------------------------------
//
// There is no generic catch-all block. Topic-specific content that doesn't fit a
// base block is modeled with a first-class typed block: declare an @block plus a
// merging @document in schema/extensions.wcl, and add a render to both template
// sets. Cards, keybindings, a CLI vocabulary — all are typed extension blocks.
// (A reference table is a `fact` whose body is a `table`, not a typed block.)
// See references/schema.md.

// ---------------------------------------------------------------------------
// Root document — gathers every block instance for the projections
// ---------------------------------------------------------------------------

// Merges with wdoc's library @document (so `site` / `page` template blocks are
// legal alongside content) and with any @document declared in extensions.wcl.
@document
type WSkillDoc {
  schema_version: utf8

  // Exactly one topic block is expected; a wskill ships ONE OR MORE skills
  // (each `skill` block pairs with an `:ai_skill` site in the skill
  // template). They are gathered as lists — not @child singles — because
  // list elements resolve omitted optional fields to `none`, which a single
  // @child block does not. Templates bind `let topic = head(topics)` /
  // `let skill = head(skills)` (the primary skill). Shipped agents are
  // document-level wdoc `agent` blocks (peers of the skills) — the merged
  // wdoc @document gathers those as `agents`.
  @children("topic") topics: list<Topic>
  @children("skill") skills: list<Skill>

  @children("source")     sources:    list<Source>
  @children("research")   research_units: list<Research>
  @children("question")   questions:  list<Question>
  @children("wskill_ref") refs:       list<WskillRef>
  @children("artifact")   artifacts:  list<Artifact>

  @children("concept")   concepts:   list<Concept>
  @children("entity")    entities:   list<Entity>
  @children("fact")      facts:      list<Fact>
  @children("term")      terms:      list<Term>
  @children("example")   examples:   list<Example>
  @children("index")     indexes:    list<Index>

  @children("procedure") procedures: list<Procedure>
}
