// vmlab landing page. `start = true` makes it the page served at `/`. The whole
// page is rendered by the custom `:vmlab_home` template (see home-template.wcl),
// which emits a self-contained marketing landing from one raw-HTML block — so
// this page carries no wdoc body blocks; `content` is unused by that template.
page index { sites = [:vmlab]  title = "Declarative VM labs"  start = true
  template = :vmlab_home
}
