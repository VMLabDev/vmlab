// Landing-page components for the `vmlab` site (ported from the wcl repo's
// docs/pages/wcl/landing-parts.wcl — keep byte-close to upstream so future
// diffs stay trivial). Each is an ordinary
// user-declared `@block(...) extends WdocBlock` whose `lower` builds a
// semantic element tree, so the same page content renders through the
// `website` template for HTML and degrades to sensible Markdown / PDF
// (headings stay headings, links ride `Inline` markdown text, chrome —
// icons, filename bars, backdrops — drops away silently).
//
// Children are rendered from the parent's materialised `@children`
// records (top-level `lp_*_el` helpers), not via a `Children {}` slot —
// the slot is HTML-only, and building the whole tree in the `lower`
// keeps all three backends consistent.
//
// Everything paints from `var(--wdoc-*, fallback)`, so the design
// follows the site `theme` / `accent` and the standard wdoc theme
// toggle — no bespoke palette, no parallel toggle script.

// ── Styling ──────────────────────────────────────────────────────────
// IMPORTANT: the heredoc is emitted verbatim into <head>, so it must be
// pure CSS — never a `//` line (CSS has no `//` comment).
stylesheet "vmlab-landing" {
  sites = [:vmlab]
  css = <<CSS
    .ws-banner .callout { display: flex; align-items: center; justify-content: center; gap: 0.75rem; max-width: 70rem; margin: 0 auto; padding: 0.45rem 1rem; border: 0; border-radius: 0; background: none; font-size: 0.85rem; }
    .ws-banner .callout-title, .ws-banner .callout-body p { margin: 0; }
    .lp-hero { position: relative; text-align: center; padding: 4.5rem 0 3rem; }
    .lp-hero > :not(.lp-hero-bg) { position: relative; }
    .lp-hero-bg { position: absolute; inset: 0; pointer-events: none; opacity: 0.55; background-image: linear-gradient(var(--wdoc-border, rgba(127,127,127,0.25)) 1px, transparent 1px), linear-gradient(90deg, var(--wdoc-border, rgba(127,127,127,0.25)) 1px, transparent 1px); background-size: 44px 44px; -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, #000 0%, transparent 72%); mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, #000 0%, transparent 72%); }
    .lp-badge { display: inline-flex; align-items: center; gap: 0.5rem; margin: 0; padding: 0.3rem 0.8rem; border: 1px solid var(--wdoc-border, rgba(127,127,127,0.35)); border-radius: 999px; background: var(--wdoc-bg-alt, transparent); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--wdoc-fg-muted, inherit); }
    .lp-badge::before { content: ""; width: 6px; height: 6px; border-radius: 999px; background: var(--wdoc-accent, #4060ff); }
    .lp-hero h1 { margin: 1.4rem auto 0; max-width: 16ch; font-size: clamp(2.4rem, 6vw, 4rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance; }
    .lp-hero .lp-lede { margin: 1.3rem auto 0; }
    .lp-lede { max-width: 60ch; font-size: 1.05rem; line-height: 1.6; color: var(--wdoc-fg-muted, inherit); }
    .lp-ctas { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem; }
    .lp-ctas p { margin: 0; }
    .lp-cta a { display: inline-flex; align-items: center; gap: 0.5rem; height: 2.6rem; padding: 0 1.25rem; border-radius: 6px; font-weight: 600; font-size: 0.9rem; text-decoration: none; }
    .lp-cta-primary a { background: var(--wdoc-accent, #4060ff); color: var(--wdoc-on-accent, #fff); border: 1px solid transparent; }
    .lp-cta-primary a::after { content: "→"; }
    .lp-cta-primary a:hover { background: color-mix(in srgb, var(--wdoc-accent, #4060ff) 85%, var(--wdoc-fg, #000) 15%); }
    .lp-cta-ghost a { background: transparent; color: inherit; border: 1px solid var(--wdoc-border, rgba(127,127,127,0.35)); font-weight: 500; }
    .lp-cta-ghost a:hover { border-color: var(--wdoc-border-strong, rgba(127,127,127,0.7)); background: var(--wdoc-bg-alt, transparent); }
    .lp-hero-footnote { margin-top: 1.4rem; font-size: 0.8rem; color: var(--wdoc-fg-subtle, inherit); }
    .lp-section { padding: 2.75rem 0 1rem; }
    .lp-section-head { display: block; text-align: center; max-width: 60ch; margin: 0 auto 2.25rem; }
    .lp-section-head h2, .lp-showcase-text h2 { margin: 0.7rem 0 0; font-size: 1.9rem; letter-spacing: -0.02em; line-height: 1.12; }
    .lp-section-head .lp-lede { margin: 0.85rem auto 0; font-size: 1rem; }
    .lp-eyebrow { margin: 0; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--wdoc-fg-subtle, inherit); }
    .lp-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(17.5rem, 1fr)); gap: 1rem; }
    .lp-card, .lp-refcard { display: flex; flex-direction: column; margin: 0; border: 1px solid var(--wdoc-border, rgba(127,127,127,0.35)); border-radius: 8px; background: var(--wdoc-bg-alt, transparent); padding: 1.4rem; }
    .lp-card:hover, .lp-refcard:hover { border-color: var(--wdoc-border-strong, rgba(127,127,127,0.7)); }
    .lp-card-icon { display: inline-flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; margin: 0 0 0.85rem; border-radius: 8px; background: color-mix(in srgb, var(--wdoc-accent, #4060ff) 14%, transparent); color: var(--wdoc-accent, #4060ff); }
    .lp-card-icon svg.wdoc-icon { width: 1.2rem; height: 1.2rem; }
    .lp-card h3 { margin: 0 0 0.4rem; font-size: 1rem; }
    .lp-card p:last-child, .lp-refcard p { margin: 0; font-size: 0.88rem; line-height: 1.6; color: var(--wdoc-fg-muted, inherit); }
    .lp-refcard-head { display: flex; align-items: center; gap: 0.65rem; margin-bottom: 0.85rem; }
    .lp-refcard-head .lp-card-icon { margin: 0; }
    .lp-refcard-name { margin: 0; font-family: var(--wdoc-font-mono, ui-monospace, monospace); font-weight: 600; font-size: 1.05rem; color: var(--wdoc-heading, inherit); }
    .lp-refcard-body { flex: 1; margin-bottom: 1rem; }
    .lp-refcard-cta { font-size: 0.85rem; font-weight: 500; }
    .lp-showcase { display: grid; grid-template-columns: minmax(0, 1fr); gap: 1.75rem; align-items: start; }
    .lp-codepanel { margin: 0; border: 1px solid var(--wdoc-border, rgba(127,127,127,0.35)); border-radius: 8px; background: var(--wdoc-bg-alt, transparent); overflow: hidden; }
    .lp-codehead { display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem 0.9rem; border-bottom: 1px solid var(--wdoc-border, rgba(127,127,127,0.25)); background: var(--wdoc-bg-inset, rgba(127,127,127,0.08)); font-family: var(--wdoc-font-mono, ui-monospace, monospace); font-size: 0.8rem; color: var(--wdoc-fg-muted, inherit); }
    .lp-codehead svg.wdoc-icon { width: 0.95rem; height: 0.95rem; }
    .lp-codetag { margin-left: auto; padding: 0.1rem 0.5rem; border: 1px solid var(--wdoc-border, rgba(127,127,127,0.35)); border-radius: 4px; font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; }
    .lp-code { margin: 0; padding: 1.1rem 1.25rem; overflow-x: auto; line-height: 1.65; font-size: 0.85rem; }
    .lp-code code { background: none; border: 0; padding: 0; }
    .lp-showcase-text { display: block; }
    .lp-showcase-text p:last-child { margin-bottom: 0; max-width: 62ch; color: var(--wdoc-fg-muted, inherit); line-height: 1.65; }
    .lp-steps-panel { border: 1px solid var(--wdoc-border, rgba(127,127,127,0.35)); border-radius: 8px; background: var(--wdoc-bg-alt, transparent); padding: 1.9rem; }
    .lp-steps-panel .lp-section-head { text-align: left; margin: 0 0 1.5rem; max-width: 60ch; }
    ol.lp-steps { list-style: none; counter-reset: lp-step; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
    ol.lp-steps > li { position: relative; padding-left: 2.5rem; }
    ol.lp-steps > li::before { counter-increment: lp-step; content: counter(lp-step); position: absolute; left: 0; top: 0; width: 1.5rem; height: 1.5rem; display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--wdoc-border, rgba(127,127,127,0.35)); border-radius: 999px; font-size: 0.75rem; font-weight: 600; font-family: var(--wdoc-font-mono, ui-monospace, monospace); color: var(--wdoc-fg-muted, inherit); }
    .lp-step-title { margin: 0 0 0.5rem; font-weight: 500; }
    .lp-cmd { margin: 0; padding: 0.65rem 0.9rem; border: 1px solid var(--wdoc-border, rgba(127,127,127,0.25)); border-radius: 6px; background: var(--wdoc-bg-inset, rgba(127,127,127,0.06)); font-size: 0.85rem; overflow-x: auto; white-space: nowrap; }
    .lp-cmd::before { content: "$ "; color: var(--wdoc-fg-subtle, inherit); font-family: var(--wdoc-font-mono, ui-monospace, monospace); }
    .lp-cmd code { background: none; border: 0; padding: 0; }
    footer.ws-footer { opacity: 1; text-align: left; padding: 0; }
    .lp-footgrid { max-width: 70rem; margin: 0 auto; padding: 2.75rem clamp(1rem, 5vw, 3rem); display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 2rem; }
    .lp-footbrand p { margin: 0 0 0.75rem; }
    .lp-footlogo { display: flex; align-items: center; gap: 0.6rem; font-family: var(--wdoc-font-mono, ui-monospace, monospace); font-weight: 600; color: var(--wdoc-heading, inherit); }
    .lp-footlogo svg.wdoc-icon { width: 1.1rem; height: 1.1rem; color: var(--wdoc-accent, #4060ff); }
    .lp-foottag { max-width: 34ch; font-size: 0.85rem; line-height: 1.6; color: var(--wdoc-fg-subtle, inherit); }
    .lp-footcol p { margin: 0 0 0.55rem; font-size: 0.85rem; }
    .lp-foothead { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--wdoc-fg-subtle, inherit); }
    .lp-footlink a { color: var(--wdoc-fg-muted, inherit); text-decoration: none; }
    .lp-footlink a:hover { color: var(--wdoc-fg, inherit); }
    .lp-footbottom { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: space-between; max-width: 70rem; margin: 0 auto; padding: 1rem clamp(1rem, 5vw, 3rem); border-top: 1px solid var(--wdoc-border, rgba(127,127,127,0.2)); }
    .lp-footbottom p { margin: 0; font-size: 0.75rem; color: var(--wdoc-fg-subtle, inherit); }
    @media (max-width: 48rem) { .lp-footgrid { grid-template-columns: 1fr 1fr; } }
    @media (prefers-reduced-motion: reduce) { .lp-hero-bg { opacity: 0.3; } }
    CSS
}

// ── Child-element helpers ────────────────────────────────────────────
// Top-level `let` fns so every parent `lower` can map its materialised
// `@children` records through them (lowering fns resolve free names via
// root lets, not lexical capture).

// A call-to-action button: a styled `<p><a></a></p>` whose link rides
// the inline-pattern engine, so Markdown keeps a real `[label](href)`.
let lp_cta_el = fn(x: LpCta) -> HtmlFundamental
  HtmlFundamental::Element {
    tag: "p", id: none,
    class: if x.primary == true { ["lp-cta", "lp-cta-primary"] } else { ["lp-cta", "lp-cta-ghost"] },
    attrs: none,
    children: [ HtmlFundamental::Inline { text: $"[${x.label}](${x.href})" } ],
  }

// One feature card: icon chip, title, body prose.
let lp_feature_el = fn(f: LpFeature) -> HtmlFundamental {
  let icon_name = if f.icon == none { "lucide.sparkles" } else { f.icon };
  HtmlFundamental::Element {
    tag: "article", id: none, class: ["lp-card"], attrs: none,
    children: [
      HtmlFundamental::Element {
        tag: "p", id: none, class: ["lp-card-icon"], attrs: none,
        children: [ HtmlFundamental::Icon { name: icon_name, class: none } ],
      },
      HtmlFundamental::Element {
        tag: "h3", id: none, class: none, attrs: none,
        children: [ HtmlFundamental::Inline { text: f.title } ],
      },
      HtmlFundamental::Element {
        tag: "p", id: none, class: none, attrs: none,
        children: [ HtmlFundamental::Inline { text: f.body } ],
      },
    ],
  }
}

// One reference-manual card, built from a data record (see `lp_cards`).
let lp_refcard_el = fn(r: LpRefCard) -> HtmlFundamental
  HtmlFundamental::Element {
    tag: "article", id: none, class: ["lp-refcard"], attrs: none,
    children: [
      HtmlFundamental::Element {
        tag: "header", id: none, class: ["lp-refcard-head"], attrs: none,
        children: [
          HtmlFundamental::Element {
            tag: "p", id: none, class: ["lp-card-icon"], attrs: none,
            children: [ HtmlFundamental::Icon { name: r.icon, class: none } ],
          },
          HtmlFundamental::Element {
            tag: "p", id: none, class: ["lp-refcard-name"], attrs: none,
            children: [ HtmlFundamental::Inline { text: $"**${r.name}**" } ],
          },
        ],
      },
      HtmlFundamental::Element {
        tag: "p", id: none, class: ["lp-refcard-body"], attrs: none,
        children: [ HtmlFundamental::Inline { text: r.summary } ],
      },
      HtmlFundamental::Element {
        tag: "p", id: none, class: ["lp-refcard-cta"], attrs: none,
        children: [ HtmlFundamental::Inline { text: $"[Read the manual](${r.href})${r.links}" } ],
      },
    ],
  }

// One getting-started step: a numbered row (the number is a CSS counter)
// with a title and a command line rendered as inline code.
let lp_step_el = fn(s: LpStep) -> HtmlFundamental
  HtmlFundamental::Element {
    tag: "li", id: none, class: none, attrs: none,
    children: [
      HtmlFundamental::Element {
        tag: "p", id: none, class: ["lp-step-title"], attrs: none,
        children: [ HtmlFundamental::Inline { text: s.title } ],
      },
      HtmlFundamental::Element {
        tag: "p", id: none, class: ["lp-cmd"], attrs: none,
        children: [ HtmlFundamental::Inline { text: $"`${s.command}`" } ],
      },
    ],
  }

// One footer column: an uppercase heading over a list of links.
let lp_footcol_el = fn(col: LpFootcol) -> HtmlFundamental {
  let links = if col.links == none { [] } else { col.links };
  HtmlFundamental::Element {
    tag: "section", id: none, class: ["lp-footcol"], attrs: none,
    children: flatten([
      [ HtmlFundamental::Element {
          tag: "p", id: none, class: ["lp-foothead"], attrs: none,
          children: [ HtmlFundamental::Inline { text: col.title } ],
      } ],
      map(links, fn(l: LpFootlink) -> HtmlFundamental
        HtmlFundamental::Element {
          tag: "p", id: none, class: ["lp-footlink"], attrs: none,
          children: [ HtmlFundamental::Inline { text: $"[${l.label}](${l.href})" } ],
        }),
    ]),
  }
}

// The eyebrow / title / lede header shared by the section wrappers.
// `cls` is the wrapping class ("lp-section-head"); the wrapper is a
// `<header>` (not a `<div>`) so Markdown descends into it as blocks and
// the `<h2>` survives as a `##` heading. Absent fields render nothing.
let lp_section_head = fn(eyebrow: utf8, title: utf8, lede: utf8, cls: utf8) -> list<HtmlFundamental> {
  let parts = flatten([
    if eyebrow == none || eyebrow == "" { [] }
    else {
      [ HtmlFundamental::Element {
          tag: "p", id: none, class: ["lp-eyebrow"], attrs: none,
          children: [ HtmlFundamental::Inline { text: eyebrow } ],
      } ]
    },
    if title == none || title == "" { [] }
    else {
      [ HtmlFundamental::Element {
          tag: "h2", id: none, class: none, attrs: none,
          children: [ HtmlFundamental::Inline { text: title } ],
      } ]
    },
    if lede == none || lede == "" { [] }
    else {
      [ HtmlFundamental::Element {
          tag: "p", id: none, class: ["lp-lede"], attrs: none,
          children: [ HtmlFundamental::Inline { text: lede } ],
      } ]
    },
  ]);
  if len(parts) == 0 { [] }
  else {
    [ HtmlFundamental::Element {
        tag: "header", id: none, class: [cls], attrs: none,
        children: parts,
    } ]
  }
}

// ── The components ───────────────────────────────────────────────────

// The hero: a decorative grid backdrop, an optional badge pill, the
// headline, the lede, CTA buttons, and an optional footnote.
@block("lp_hero")
type LpHero extends WdocBlock {
  @doc("The main headline (rendered as the page `<h1>`).")
  @inline(0) heading: utf8
  @doc("The supporting paragraph under the headline.")
  lede: utf8
  @doc("Optional uppercase badge pill above the headline.")
  badge: utf8?
  @doc("Optional small print under the CTA buttons.")
  footnote: utf8?
  id: identifier?
  @children("lp_cta") ctas: list<LpCta>?

  lower = fn(b: LpHero) -> list<HtmlFundamental> {
    let ctas = if b.ctas == none { [] } else { b.ctas };
    [
      HtmlFundamental::Element {
        tag: "section", id: b.id, class: ["lp-hero"], attrs: none,
        children: flatten([
          [ HtmlFundamental::Element {
              tag: "div", id: none, class: ["lp-hero-bg"],
              attrs: [["aria-hidden", "true"]], children: [],
          } ],
          if b.badge == none { [] }
          else {
            [ HtmlFundamental::Element {
                tag: "p", id: none, class: ["lp-badge"], attrs: none,
                children: [ HtmlFundamental::Inline { text: b.badge } ],
            } ]
          },
          [ HtmlFundamental::Element {
              tag: "h1", id: none, class: none, attrs: none,
              children: [ HtmlFundamental::Inline { text: b.heading } ],
          } ],
          [ HtmlFundamental::Element {
              tag: "p", id: none, class: ["lp-lede"], attrs: none,
              children: [ HtmlFundamental::Inline { text: b.lede } ],
          } ],
          if len(ctas) == 0 { [] }
          else {
            [ HtmlFundamental::Element {
                tag: "nav", id: none, class: ["lp-ctas"], attrs: none,
                children: map(ctas, lp_cta_el),
            } ]
          },
          if b.footnote == none { [] }
          else {
            [ HtmlFundamental::Element {
                tag: "p", id: none, class: ["lp-hero-footnote"], attrs: none,
                children: [ HtmlFundamental::Inline { text: b.footnote } ],
            } ]
          },
        ]),
      },
    ]
  }
}

// A CTA button (child of `lp_hero`). `primary = true` fills it with the
// accent colour; otherwise it renders as a ghost/outline button.
@block("lp_cta")
type LpCta extends WdocBlock {
  @inline(0) label: utf8
  href: utf8
  primary: bool?
  id: identifier?
  lower = fn(x: LpCta) -> list<HtmlFundamental> [ lp_cta_el(x) ]
}

// A feature-card grid section with an optional centred header.
@block("lp_features")
type LpFeatures extends WdocBlock {
  eyebrow: utf8?
  title: utf8?
  lede: utf8?
  id: identifier?
  @children("lp_feature") items: list<LpFeature>?

  lower = fn(b: LpFeatures) -> list<HtmlFundamental> {
    let items = if b.items == none { [] } else { b.items };
    [
      HtmlFundamental::Element {
        tag: "section", id: b.id, class: ["lp-section"], attrs: none,
        children: flatten([
          lp_section_head(b.eyebrow, b.title, b.lede, "lp-section-head"),
          if len(items) == 0 { [] }
          else {
            [ HtmlFundamental::Element {
                tag: "section", id: none, class: ["lp-grid"], attrs: none,
                children: map(items, lp_feature_el),
            } ]
          },
        ]),
      },
    ]
  }
}

// One feature card (child of `lp_features`).
@block("lp_feature")
type LpFeature extends WdocBlock {
  @inline(0) title: utf8
  body: utf8
  @doc("Icon as `pack.name` (default `lucide.sparkles`).")
  icon: utf8?
  id: identifier?
  lower = fn(f: LpFeature) -> list<HtmlFundamental> [ lp_feature_el(f) ]
}

// A reference card record for `lp_cards` (built with `map(...)` from
// `included_sites(...)` data, so the grid stays discovery-driven).
type LpRefCard {
  name: utf8
  summary: utf8
  href: utf8
  icon: utf8
  @doc("Extra markdown appended to the CTA line, e.g. ` · [deck](…)`.")
  links: utf8
}

// A data-driven card grid: same shell as `lp_features`, but the cards
// come from a value field instead of child blocks.
@block("lp_cards")
type LpCards extends WdocBlock {
  eyebrow: utf8?
  title: utf8?
  lede: utf8?
  id: identifier?
  cards: list<LpRefCard>?

  lower = fn(b: LpCards) -> list<HtmlFundamental> {
    let cards = if b.cards == none { [] } else { b.cards };
    [
      HtmlFundamental::Element {
        tag: "section", id: b.id, class: ["lp-section"], attrs: none,
        children: flatten([
          lp_section_head(b.eyebrow, b.title, b.lede, "lp-section-head"),
          if len(cards) == 0 { [] }
          else {
            [ HtmlFundamental::Element {
                tag: "section", id: none, class: ["lp-grid"], attrs: none,
                children: map(cards, lp_refcard_el),
            } ]
          },
        ]),
      },
    ]
  }
}

// A code showcase: a filename-chromed, syntax-highlighted panel (fed by
// a nested stdlib `code` block) above the explanatory text. The chrome
// (filename bar, language tag) is `Raw`, so Markdown drops it and keeps
// just the fenced listing.
@block("lp_showcase")
type LpShowcase extends WdocBlock {
  heading: utf8
  body: utf8
  eyebrow: utf8?
  id: identifier?
  @children("code") snippets: list<Code>?

  lower = fn(b: LpShowcase) -> list<HtmlFundamental> {
    let snips = if b.snippets == none { [] } else { b.snippets };
    let panel =
      if len(snips) == 0 { [] }
      else {
        let sn = at(snips, 0);
        let fname = if sn.filename == none { "" } else { sn.filename };
        let lang = format("{}", sn.language);
        [
          HtmlFundamental::Element {
            tag: "figure", id: none, class: ["lp-codepanel"], attrs: none,
            children: [
              HtmlFundamental::Element {
                tag: "figcaption", id: none, class: ["lp-codehead"], attrs: none,
                children: [
                  HtmlFundamental::Icon { name: "lucide.file-text", class: none },
                  HtmlFundamental::Element {
                    tag: "span", id: none, class: ["lp-codename"], attrs: none,
                    children: [ HtmlFundamental::Raw { html: fname } ],
                  },
                  HtmlFundamental::Element {
                    tag: "span", id: none, class: ["lp-codetag"], attrs: none,
                    children: [ HtmlFundamental::Raw { html: lang } ],
                  },
                ],
              },
              HtmlFundamental::Element {
                tag: "pre", id: none, class: ["lp-code"], attrs: none,
                children: [
                  HtmlFundamental::Element {
                    tag: "code", id: none, class: [format("language-{}", lang)], attrs: none,
                    children: [ HtmlFundamental::Highlighted { source: sn.source, language: lang } ],
                  },
                ],
              },
            ],
          },
        ]
      };
    [
      HtmlFundamental::Element {
        tag: "section", id: b.id, class: ["lp-section", "lp-showcase"], attrs: none,
        children: flatten([
          panel,
          lp_section_head(b.eyebrow, b.heading, b.body, "lp-showcase-text"),
        ]),
      },
    ]
  }
}

// A getting-started panel: header plus numbered steps, each a title over
// a command line.
@block("lp_steps")
type LpSteps extends WdocBlock {
  eyebrow: utf8?
  title: utf8?
  lede: utf8?
  id: identifier?
  @children("lp_step") steps: list<LpStep>?

  lower = fn(b: LpSteps) -> list<HtmlFundamental> {
    let steps = if b.steps == none { [] } else { b.steps };
    [
      HtmlFundamental::Element {
        tag: "section", id: b.id, class: ["lp-section"], attrs: none,
        children: [
          HtmlFundamental::Element {
            tag: "article", id: none, class: ["lp-steps-panel"], attrs: none,
            children: flatten([
              lp_section_head(b.eyebrow, b.title, b.lede, "lp-section-head"),
              if len(steps) == 0 { [] }
              else {
                [ HtmlFundamental::Element {
                    tag: "ol", id: none, class: ["lp-steps"], attrs: none,
                    children: map(steps, lp_step_el),
                } ]
              },
            ]),
          },
        ],
      },
    ]
  }
}

// One numbered step (child of `lp_steps`).
@block("lp_step")
type LpStep extends WdocBlock {
  @inline(0) title: utf8
  command: utf8
  id: identifier?
  lower = fn(s: LpStep) -> list<HtmlFundamental> [ lp_step_el(s) ]
}

// The multi-column site footer: a brand cell (icon + wordmark + tagline)
// beside link columns, over a bottom bar with the copyright and a note.
@block("lp_footer")
type LpFooter extends WdocBlock {
  @doc("Short prose under the brand wordmark.")
  tagline: utf8
  @doc("Brand wordmark text (chrome — dropped in Markdown).")
  brand: utf8?
  copyright: utf8?
  note: utf8?
  id: identifier?
  @children("lp_footcol") columns: list<LpFootcol>?

  lower = fn(b: LpFooter) -> list<HtmlFundamental> {
    let cols = if b.columns == none { [] } else { b.columns };
    let brand = if b.brand == none { "" } else { b.brand };
    let bottom = flatten([
      if b.copyright == none { [] }
      else {
        [ HtmlFundamental::Element {
            tag: "p", id: none, class: none, attrs: none,
            children: [ HtmlFundamental::Inline { text: b.copyright } ],
        } ]
      },
      if b.note == none { [] }
      else {
        [ HtmlFundamental::Element {
            tag: "p", id: none, class: none, attrs: none,
            children: [ HtmlFundamental::Inline { text: b.note } ],
        } ]
      },
    ]);
    flatten([
      [ HtmlFundamental::Element {
          tag: "nav", id: b.id, class: ["lp-footgrid"], attrs: none,
          children: flatten([
            [ HtmlFundamental::Element {
                tag: "header", id: none, class: ["lp-footbrand"], attrs: none,
                children: [
                  HtmlFundamental::Element {
                    tag: "p", id: none, class: ["lp-footlogo"], attrs: none,
                    children: [
                      HtmlFundamental::Icon { name: "lucide.square-terminal", class: none },
                      HtmlFundamental::Element {
                        tag: "span", id: none, class: none, attrs: none,
                        children: [ HtmlFundamental::Raw { html: brand } ],
                      },
                    ],
                  },
                  HtmlFundamental::Element {
                    tag: "p", id: none, class: ["lp-foottag"], attrs: none,
                    children: [ HtmlFundamental::Inline { text: b.tagline } ],
                  },
                ],
            } ],
            map(cols, lp_footcol_el),
          ]),
      } ],
      if len(bottom) == 0 { [] }
      else {
        [ HtmlFundamental::Element {
            tag: "section", id: none, class: ["lp-footbottom"], attrs: none,
            children: bottom,
        } ]
      },
    ])
  }
}

// One footer link column (child of `lp_footer`). Links may be authored
// as nested `lp_footlink` blocks or spliced in as data with
// `links = map(...)` (computed `@children`).
@block("lp_footcol")
type LpFootcol extends WdocBlock {
  @inline(0) title: utf8
  id: identifier?
  @children("lp_footlink") links: list<LpFootlink>?
  lower = fn(col: LpFootcol) -> list<HtmlFundamental> [ lp_footcol_el(col) ]
}

// One footer link (child of `lp_footcol`).
@block("lp_footlink")
type LpFootlink extends WdocBlock {
  @inline(0) label: utf8
  href: utf8
  id: identifier?
  lower = fn(l: LpFootlink) -> list<HtmlFundamental> [
    HtmlFundamental::Element {
      tag: "p", id: none, class: ["lp-footlink"], attrs: none,
      children: [ HtmlFundamental::Inline { text: $"[${l.label}](${l.href})" } ],
    },
  ]
}
